# Server-only OpenAI credential. Never expose this with NEXT_PUBLIC_.
OPENAI_API_KEY=

# Live GPT requests are rejected unless this authoritative server flag is true.
REASONPATCH_LIVE_MODE=false

# Reveals the live-mode UI. Keep false for the public fixture deployment.
NEXT_PUBLIC_REASONPATCH_LIVE_MODE=false

# Optional stable salt for hashing best-effort rate-limit identities.
REASONPATCH_RATE_LIMIT_SALT=
